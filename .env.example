# ── Auth0 ─────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-client-id-here
AUTH0_CLIENT_SECRET=your-client-secret-here
AUTH0_BASE_URL=https://your-app.up.railway.app
AUTH0_SECRET=replace-with-64-char-random-hex

# ── Groq ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your-groq-api-key-here

# ── HMAC (same value locally and on Railway) ───────────────────────────────
BRIDGE_HMAC_SECRET=replace-with-64-char-random-hex

# ── Local only ────────────────────────────────────────────────────────────
BRIDGE_URL=https://your-app.up.railway.app
